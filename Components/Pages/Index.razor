@page "/"
@using VideoScheduler.Data
@using VideoScheduler.Data.Models
@using VideoScheduler.Services
@inject SchedulePlanner Planner
@inject VlcService Vlc
@inject AutomationService Automation
@inject YamlRepository Repository
@implements IDisposable

<PageTitle>Index</PageTitle>

<h1>Upcoming Schedule</h1>

<div class="mb-3 d-flex gap-2 align-items-end">
    <div>
        <label class="form-label">Days to forecast:</label>
        <input type="number" class="form-control" @bind="DaysToForecast" min="1" max="14" style="width: 80px;" />
    </div>
    <button class="btn btn-primary" @onclick="Generate">Generate</button>
    <button class="btn btn-warning" @onclick="RegenerateCurrent">Regenerate Current Block</button>
    
    <div class="form-check form-switch ms-3 mb-2">
        <input class="form-check-input" type="checkbox" id="autoPlaySwitch" checked="@Automation.IsAutoPlaying" @onchange="ToggleAutoPlay">
        <label class="form-check-label" for="autoPlaySwitch">Sync with VLC</label>
    </div>
</div>

@if (Planner.CurrentPlaylist != null)
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Title</th>
                <th>Type</th>
                <th>Source</th>
                <th>Duration</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Planner.CurrentPlaylist.Where(i => i.EstimatedStartTime.AddSeconds(i.DurationSec) > DateTime.Now))
            {
                <tr class="@(IsCurrentItem(item) ? "table-primary" : "")">
                    <td>@item.EstimatedStartTime.ToString("ddd MMM dd")</td>
                    <td>@item.EstimatedStartTime.ToString("HH:mm:ss")</td>
                    <td>@item.Title</td>
                    <td>@item.Type</td>
                    <td>@item.Source</td>
                    <td>@item.Duration</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int DaysToForecast { get; set; } = 3;
    private System.Threading.Timer? _uiTimer;

    protected override void OnInitialized()
    {
        DaysToForecast = Repository.AppState.ForecastDays;
        Planner.OnPlaylistUpdated += RefreshUI;
        Automation.OnStateChanged += RefreshUI;
        // Refresh UI every second to update "Current Item" highlight
        _uiTimer = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged), null, 0, 1000);
    }

    public void Dispose()
    {
        Planner.OnPlaylistUpdated -= RefreshUI;
        Automation.OnStateChanged -= RefreshUI;
        _uiTimer?.Dispose();
    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleAutoPlay(ChangeEventArgs e)
    {
        Automation.ToggleAutoPlay((bool)(e.Value ?? false));
    }

    private void Generate()
    {
        Repository.AppState.ForecastDays = DaysToForecast;
        Planner.RefreshForecast();
    }

    private void RegenerateCurrent()
    {
        Repository.AppState.ForecastDays = DaysToForecast;
        Planner.RefreshForecast(forceCurrentBlock: true);
    }

    private bool IsCurrentItem(PlaylistItem item)
    {
        if (Planner.CurrentPlaylist == null) return false;
        
        var now = DateTime.Now;
        var index = Planner.CurrentPlaylist.IndexOf(item);
        
        DateTime endTime;
        
        if (index < Planner.CurrentPlaylist.Count - 1)
        {
            var nextItem = Planner.CurrentPlaylist[index + 1];
            endTime = nextItem.EstimatedStartTime;
        }
        else
        {
            endTime = item.EstimatedStartTime.AddSeconds(item.DurationSec);
        }

        return now >= item.EstimatedStartTime && now < endTime;
    }
}

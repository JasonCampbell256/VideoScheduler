@page "/vlc-test"
@using VideoScheduler.Data
@inject VlcService Vlc
@inject YamlRepository Repository

@implements IDisposable

<h3>VLC Connection Test</h3>

<p class="text-muted">
    This page is used to verify the connection to the VLC media player instance. 
    Use the controls below to ensure that the application can successfully send commands to VLC.
</p>

<div class="alert @(IsConnected ? "alert-success" : "alert-warning")">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <strong>Status:</strong> @(IsConnected ? "Connected" : "Disconnected")
            @if (!IsConnected)
            {
                <button class="btn btn-sm btn-outline-dark ms-3" @onclick="Connect">Connect to VLC</button>
            }
        </div>
        @if (CurrentStatus != null && IsConnected)
        {
            <div>
                <span class="badge bg-info text-dark me-2">@CurrentStatus.State.ToUpper()</span>
                <span class="me-2">@FormatTime(CurrentStatus.Time) / @FormatTime(CurrentStatus.Length)</span>
            </div>
        }
    </div>
    @if (CurrentStatus != null && !string.IsNullOrEmpty(CurrentStatus.Filename))
    {
        <div class="mt-2">
            <strong>Now Playing:</strong> @CurrentStatus.Filename
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Vlc.LastError))
{
    <div class="alert alert-danger">
        <strong>Connection Failed:</strong> @Vlc.LastError
        <br/>
        <small>Ensure VLC is running with: <code>vlc --extraintf http --http-password admin --http-port 8080</code></small>
    </div>
}

<div class="card mb-3">
    <div class="card-header">Manual Control</div>
    <div class="card-body">
        <div class="input-group mb-3">
            <span class="input-group-text">File Path</span>
            <input type="text" class="form-control" @bind="FilePath" placeholder="C:\Path\To\Video.mp4" />
            <button class="btn btn-primary" @onclick="PlayFile" disabled="@(!IsConnected)">Play</button>
        </div>

        <div class="btn-group">
            <button class="btn btn-secondary" @onclick="Pause" disabled="@(!IsConnected)">Pause/Resume</button>
            <button class="btn btn-danger" @onclick="Stop" disabled="@(!IsConnected)">Stop</button>
        </div>

        <div class="mt-3">
            <label>Seek (Seconds)</label>
            <div class="input-group">
                <input type="number" class="form-control" @bind="SeekSeconds" />
                <button class="btn btn-outline-secondary" @onclick="Seek" disabled="@(!IsConnected)">Go</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Quick Play from Library</div>
    <div class="card-body">
        <div style="max-height: 300px; overflow-y: auto;">
            <ul class="list-group">
                @foreach (var show in Repository.Library.Shows)
                {
                    foreach (var ep in show.Episodes)
                    {
                        <button class="list-group-item list-group-item-action" @onclick="() => PlayAsset(ep.FilePath)">
                            @show.Title - @ep.Title
                        </button>
                    }
                }
                @foreach (var movie in Repository.Library.Movies)
                {
                    <button class="list-group-item list-group-item-action" @onclick="() => PlayAsset(movie.FilePath)">
                        [Movie] @movie.Title
                    </button>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    private bool IsConnected => Vlc.IsConnected;
    private string FilePath { get; set; } = string.Empty;
    private int SeekSeconds { get; set; } = 30;
    private VlcStatus? CurrentStatus { get; set; }
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        // Try auto-connect
        await Connect();
        // Start polling
        _timer = new System.Threading.Timer(async _ => await UpdateStatus(), null, 0, 1000);
    }

    private async Task UpdateStatus()
    {
        if (IsConnected)
        {
            CurrentStatus = await Vlc.GetStatusAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Connect()
    {
        await Vlc.ConnectAsync();
        await UpdateStatus();
    }

    private string FormatTime(int seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.ToString(@"hh\:mm\:ss");
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }

    private async Task PlayFile()
    {
        if (!string.IsNullOrWhiteSpace(FilePath))
        {
            await Vlc.Play(FilePath);
        }
    }

    private async Task PlayAsset(string path)
    {
        FilePath = path;
        StateHasChanged();
        await PlayFile();
    }

    private async Task Pause()
    {
        await Vlc.Pause();
    }

    private async Task Stop()
    {
        await Vlc.Stop();
    }

    private async Task Seek()
    {
        await Vlc.Seek(SeekSeconds);
    }
}

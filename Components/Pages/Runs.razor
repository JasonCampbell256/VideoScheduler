@page "/runs"
@using VideoScheduler.Data
@using VideoScheduler.Data.Models
@using VideoScheduler.Services
@inject YamlRepository Repository
@inject SchedulePlanner Planner

<h3>Show Runs</h3>

<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Runs</span>
                <button class="btn btn-sm btn-primary" @onclick="CreateRun">+</button>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var run in Repository.Library.Runs)
                {
                    <button class="list-group-item list-group-item-action @(SelectedRun == run ? "active" : "")" 
                            @onclick="() => SelectRun(run)">
                        @run.Name
                    </button>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        @if (SelectedRun != null)
        {
            <div class="card">
                <div class="card-header">
                    <div class="input-group">
                        <input type="text" class="form-control" @bind="SelectedRun.Name" readonly="@(!IsEditing)" />
                        @if (IsEditing)
                        {
                            <button class="btn btn-success" @onclick="Save">Save</button>
                            @if (IsDeleteConfirming)
                            {
                                <span class="mx-2 text-danger fw-bold align-self-center">Sure?</span>
                                <button class="btn btn-danger" @onclick="ConfirmDelete">Yes</button>
                                <button class="btn btn-secondary" @onclick="CancelDelete">No</button>
                            }
                            else
                            {
                                <button class="btn btn-danger" @onclick="DeleteRun">Delete</button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="StartEdit">Edit</button>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Show</label>
                        <select class="form-select" @bind="SelectedRun.ShowId" disabled="@(!IsEditing)" @bind:after="OnShowChanged">
                            <option value="">-- Select Show --</option>
                            @foreach (var show in Repository.Library.Shows.OrderBy(s => s.Title))
                            {
                                <option value="@show.Id">@show.Title</option>
                            }
                        </select>
                    </div>

                    @if (!string.IsNullOrEmpty(SelectedRun.ShowId))
                    {
                        var show = Repository.Library.Shows.FirstOrDefault(s => s.Id == SelectedRun.ShowId);
                        if (show != null)
                        {
                            var currentEp = show.Episodes.FirstOrDefault(e => e.Id == SelectedRun.CurrentEpisodeId);
                            <div class="mb-3">
                                <label class="form-label">Current Episode</label>
                                <select class="form-select" @bind="SelectedRun.CurrentEpisodeId" disabled="@(!IsEditing)">
                                    @foreach (var ep in show.Episodes)
                                    {
                                        <option value="@ep.Id">S@(ep.Season) E@(ep.Number) - @ep.Title</option>
                                    }
                                </select>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">First Episode <small class="text-muted">(optional)</small></label>
                                    <select class="form-select" @bind="SelectedRun.FirstEpisodeId" disabled="@(!IsEditing)">
                                        <option value="">-- From Start --</option>
                                        @foreach (var ep in show.Episodes)
                                        {
                                            <option value="@ep.Id">S@(ep.Season) E@(ep.Number) - @ep.Title</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Episode <small class="text-muted">(optional)</small></label>
                                    <select class="form-select" @bind="SelectedRun.LastEpisodeId" disabled="@(!IsEditing)">
                                        <option value="">-- To End --</option>
                                        @foreach (var ep in show.Episodes)
                                        {
                                            <option value="@ep.Id">S@(ep.Season) E@(ep.Number) - @ep.Title</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="randomizeCheck"
                                           checked="@SelectedRun.Randomize"
                                           disabled="@(!IsEditing)"
                                           @onchange="e => SelectedRun.Randomize = (bool)(e.Value ?? false)" />
                                    <label class="form-check-label" for="randomizeCheck">
                                        Shuffle mode <small class="text-muted">(randomize episode order, no repeats until all played)</small>
                                    </label>
                                </div>
                            </div>

                            @if (ValidationError != null)
                            {
                                <div class="alert alert-danger py-2">@ValidationError</div>
                            }

                            <div class="alert alert-info">
                                @if (SelectedRun.Randomize)
                                {
                                    <span>Shuffle mode — random episode from range</span>
                                }
                                else if (currentEp != null)
                                {
                                    <span>Next to play: @currentEp.Title (S@(currentEp.Season) E@(currentEp.Number))</span>
                                }
                                else
                                {
                                    <span>Next to play: None selected</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">Select a run to edit or create a new one.</div>
        }
    </div>
</div>

@code {
    private ShowRun? SelectedRun { get; set; }
    private bool IsEditing { get; set; } = false;
    private bool IsDeleteConfirming { get; set; } = false;
    private string? ValidationError { get; set; }

    private void SelectRun(ShowRun run)
    {
        SelectedRun = run;
        IsEditing = false;
        IsDeleteConfirming = false;
        ValidationError = null;
    }

    private void StartEdit()
    {
        IsEditing = true;
        ValidationError = null;
    }

    private void OnShowChanged()
    {
        // Clear episode bounds when the show changes to avoid stale IDs
        if (SelectedRun != null)
        {
            SelectedRun.FirstEpisodeId = null;
            SelectedRun.LastEpisodeId = null;
        }
    }

    private void CreateRun()
    {
        var newRun = new ShowRun
        {
            Id = Guid.NewGuid().ToString().Substring(0, 8),
            Name = "New Run",
            ShowId = "",
            CurrentEpisodeId = ""
        };
        Repository.Library.Runs.Add(newRun);
        SelectedRun = newRun;
        IsEditing = true;
        IsDeleteConfirming = false;
        ValidationError = null;
    }

    private void DeleteRun()
    {
        IsDeleteConfirming = true;
    }

    private void ConfirmDelete()
    {
        if (SelectedRun != null)
        {
            Repository.Library.Runs.Remove(SelectedRun);
            SelectedRun = null;
            IsEditing = false;
            IsDeleteConfirming = false;
            Repository.SaveLibrary();
        }
    }

    private void CancelDelete()
    {
        IsDeleteConfirming = false;
    }

    private void Save()
    {
        if (SelectedRun == null) return;

        // Validate episode bounds
        if (!string.IsNullOrEmpty(SelectedRun.FirstEpisodeId) && !string.IsNullOrEmpty(SelectedRun.LastEpisodeId))
        {
            var show = Repository.Library.Shows.FirstOrDefault(s => s.Id == SelectedRun.ShowId);
            if (show != null)
            {
                var firstIdx = show.Episodes.FindIndex(e => e.Id == SelectedRun.FirstEpisodeId);
                var lastIdx = show.Episodes.FindIndex(e => e.Id == SelectedRun.LastEpisodeId);
                if (firstIdx >= 0 && lastIdx >= 0 && firstIdx >= lastIdx)
                {
                    ValidationError = "First episode must come before the last episode.";
                    return;
                }
            }
        }

        // Clear shuffle queue when settings change so it rebuilds cleanly
        SelectedRun.ShuffleQueue.Clear();

        ValidationError = null;
        IsEditing = false;
        Repository.SaveLibrary();
        Planner.RefreshForecast(SelectedRun.Id);
    }
}
